@startuml
title DHBW Memory — Class Diagram\nModel · Controller · View — Spring Boot + Vaadin\n<size:11>Author: Markus Wenninger</size>

' ---------- skinparams ----------
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundCorner 14
skinparam packageStyle rectangle
skinparam dpi 150
skinparam defaultFontName "Inter, Helvetica"
skinparam nodesep 55
skinparam ranksep 90

' Orthogonal routing → all arrows run as straight horizontal/vertical
' segments connected by 90° corners. No diagonals, no tangles.
skinparam linetype ortho

skinparam ArrowColor #4A4A4A
skinparam ArrowFontColor #4A4A4A
skinparam ArrowFontSize 11
skinparam ArrowThickness 1.1

skinparam ClassBorderThickness 1.3
skinparam ClassFontStyle bold
skinparam ClassStereotypeFontSize 11

skinparam PackageBorderColor #9AA0A6
skinparam PackageBackgroundColor #FFFFFF
skinparam PackageFontStyle bold
skinparam PackageFontColor #2C2F33

' Per-stereotype colour palette — one hue per architectural layer.
skinparam class {
  BackgroundColor<<entity>>       #E8F1FB
  BorderColor<<entity>>           #2F6FB0
  BackgroundColor<<enumeration>>  #FFF3D6
  BorderColor<<enumeration>>      #B8860B
  BackgroundColor<<service>>      #FFE7D6
  BorderColor<<service>>          #C2683A
  BackgroundColor<<route>>        #F1E4FB
  BorderColor<<route>>            #7E3FAE
  BackgroundColor<<component>>    #EFE4FB
  BorderColor<<component>>        #6A2EAE
  BackgroundColor<<dialog>>       #FBE4F3
  BorderColor<<dialog>>           #AE2E83
  BackgroundColor<<util>>         #ECECEC
  BorderColor<<util>>             #707070
  BackgroundColor<<app>>          #E1F4E1
  BorderColor<<app>>              #2F8F3F
}

hide empty members

' ===========================================================
' ROW 1 — APPLICATION ENTRY POINT
' ===========================================================
package "de.dhbw.memory" as PApp <<Frame>> {
  class MemoryApplication <<app>> {
    .. implements AppShellConfigurator ..
    + {static} main(args : String[])
    + configurePage(settings : AppShellSettings)
  }
}

' ===========================================================
' ROW 2 — VIEW LAYER (Vaadin @Route classes)
' ===========================================================
package "de.dhbw.memory.view" as PView <<Frame>> {
  class StartView <<route>> {
    .. extends VerticalLayout ..
    .. @Route("") ..
    + StartView(gameService : GameService)
    + onThemeSync(pref : String)
  }
  class GameView <<route>> {
    .. extends VerticalLayout ..
    .. implements BeforeEnterObserver ..
    .. @Route("game") ..
    + GameView(gameService : GameService)
    + beforeEnter(event : BeforeEnterEvent)
    + handleKeyboardFlip(position : int)
    + setKeyboardFocus(position : int)
  }
  class Labels <<util>> {
    + {static} pairsLabel(score : int) : String
  }
}

' ===========================================================
' ROW 3 — VIEW SUPPORT (components on the left, dialogs on the right)
' ===========================================================
package "view.component" as PComp <<Frame>> {
  class "SegmentedControl<T>" as SegmentedControl <<component>> {
    .. extends Div ..
    + SegmentedControl()
    + withVariant(cssClass : String) : SegmentedControl<T>
    + setItems(items : T...)
    + setRenderer(renderer)
    + setValue(value : T)
    + getValue() : T
    + setAriaLabel(label : String)
    + addValueChangeListener(listener)
  }
  class MemoryCard <<component>> {
    .. extends Div ..
    + MemoryCard(position, theme, motif, onClick)
    + playEntranceAnimation()
    + applyState(card, recentlyMatched, mismatched, waiting, focused)
  }
}

package "view.dialog" as PDialog <<Frame>> {
  class HelpDialog <<dialog>> {
    .. extends Dialog ..
    + HelpDialog(singlePlayer : boolean)
  }
  class QuitConfirmDialog <<dialog>> {
    .. extends Dialog ..
    + QuitConfirmDialog(onConfirm : Runnable)
  }
  class EndGameDialog <<dialog>> {
    .. extends Dialog ..
    + EndGameDialog(game, elapsedSeconds, onSameSettings, onNewSetup)
  }
}

' ===========================================================
' ROW 4 — CONTROLLER LAYER
' ===========================================================
package "de.dhbw.memory.controller" as PCtrl <<Frame>> {
  class GameService <<service>> {
    .. @Service @UIScope ..
    + startGame(playerNames : List<String>, gridSize : int, theme : Theme)
    + flip(position : int, ui : UI, afterReset : Runnable) : FlipResult
    + getGame() : Game
    + getTheme() : Theme
    + getElapsedSeconds() : long
    + isWaitingForFlipBack() : boolean
    + shutdown()
  }
}

' ===========================================================
' ROW 5 — MODEL LAYER (pure Java — no Spring, no Vaadin)
' ===========================================================
package "de.dhbw.memory.model" as PModel <<Frame>> {

  class Game <<entity>> {
    + Game(players : List<Player>, board : Board)
    + flip(position : int) : FlipResult
    + resetMismatch()
    + isFinished() : boolean
    + winner() : Player
    + isTie() : boolean
    + getActivePlayer() : Player
    + getTotalTurns() : int
    + getPlayers() : List<Player>
    + getBoard() : Board
  }

  class Board <<entity>> {
    + Board(size : int, theme : Theme)
    + shuffle(seed : long)
    + getCards() : List<Card>
    + getCardAt(position : int) : Card
    + getSize() : int
  }

  class Player <<entity>> {
    + Player(name : String)
    + getName() : String
    + getScore() : int
    + addPoint()
    + addTurn()
    + getTurns() : int
  }

  class Card <<entity>> {
    + Card(id : int, motif : String)
    + getId() : int
    + getMotif() : String
    + isFaceUp() : boolean
    + isMatched() : boolean
    + flip()
    + match()
  }

  enum Theme <<enumeration>> {
    CRYPTO
    LANGUAGES
    SPACE
    --
    + getFolder() : String
    + getMotifsFor(gridSize : int) : List<String>
    + getDisplayName(motif : String) : String
  }

  enum FlipResult <<enumeration>> {
    FIRST_FLIP
    MATCH
    NO_MATCH
    INVALID
  }
}

' ===========================================================
' RELATIONSHIPS — structural only, kept short for clarity.
' (Implicit edges intentionally omitted: Spring component scan,
'  MemoryCard ← Card/Theme passed via ctor, EndGameDialog ← Player
'  via Game.getPlayers, StartView ← Theme passed through to start.)
' ===========================================================

' Views → controller (single arrow per view, vertical drop)
StartView ..> GameService
GameView  ..> GameService

' View composition (short, in-package — no cross-package routing)
GameView "1" *-- "16..36" MemoryCard
GameView ..> HelpDialog
GameView ..> QuitConfirmDialog
GameView ..> EndGameDialog
StartView ..> SegmentedControl

' Controller → model (ownership edge + enum dependencies)
GameService "1" o-- "0..1" Game
GameService ..> Theme
GameService ..> FlipResult

' Model internal (composition tree + enum links)
Game  "1" *-- "1..2"    Player
Game  "1" *-- "1"       Board
Board "1" *-- "16..36"  Card
Board ..> Theme
Game  ..> FlipResult

' ===========================================================
' LAYOUT — strict top→bottom rows + side-by-side groupings.
' Hidden edges lock package order so Graphviz keeps each row tight
' and ortho routing has clean lanes for the visible arrows.
' ===========================================================
PApp    -[hidden]down-  PView
PView   -[hidden]down-  PComp
PView   -[hidden]down-  PDialog
PComp   -[hidden]right- PDialog
PComp   -[hidden]down-  PCtrl
PDialog -[hidden]down-  PCtrl
PCtrl   -[hidden]down-  PModel

' Tighten in-package layout
StartView -[hidden]right- GameView
GameView  -[hidden]right- Labels
Game      -[hidden]right- Board
Player    -[hidden]right- Card
Card      -[hidden]right- Theme
Theme     -[hidden]right- FlipResult

legend right
  |= Colour |= Layer |
  | <#E1F4E1> | Application entry point |
  | <#F1E4FB> | Vaadin @Route view |
  | <#EFE4FB> | Reusable Vaadin component |
  | <#FBE4F3> | Vaadin modal dialog |
  | <#ECECEC> | View-layer utility |
  | <#FFE7D6> | Spring @Service controller |
  | <#E8F1FB> | Model entity (pure Java) |
  | <#FFF3D6> | Enumeration |
  |  |  |
  |= Arrow |= Meaning |
  | ◆── | Composition |
  | ◇── | Aggregation |
  | ··▶ | Dependency / "uses" |
endlegend

@enduml
