@startuml DHBW Memory — Class Diagram
title DHBW Memory — Class Diagram\nModel · Controller · View (Spring Boot + Vaadin)

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundCorner 8
skinparam packageStyle rectangle
skinparam dpi 140
skinparam defaultFontName "Inter, Helvetica"
skinparam nodesep 60
skinparam ranksep 70
skinparam ArrowColor #555555
skinparam ClassBorderColor #444444
skinparam ClassBackgroundColor #FAFAFA
skinparam PackageBorderColor #888888
skinparam PackageBackgroundColor #FFFFFF
skinparam stereotypeCBackgroundColor #EAF2FF
skinparam stereotypeEBackgroundColor #FFF1D6
skinparam stereotypeABackgroundColor #E8F5E9

hide empty members

' ===========================================================
' APPLICATION ENTRY POINT
' ===========================================================
package "de.dhbw.memory" as PApp <<Frame>> {
  class MemoryApplication <<@SpringBootApplication>> {
    + {static} main(args : String[]) : void
    + configurePage(settings : AppShellSettings) : void
  }
}

' ===========================================================
' VIEW LAYER (Vaadin — never mutates model state directly)
' ===========================================================
package "de.dhbw.memory.view" as PView <<Frame>> {
  class StartView <<@Route("")>> {
    + StartView(gameService : GameService)
    + onThemeSync(pref : String) : void
  }
  class GameView <<@Route("game")>> {
    + GameView(gameService : GameService)
    + beforeEnter(event : BeforeEnterEvent) : void
  }
}

package "de.dhbw.memory.view.dialog" as PDialog <<Frame>> {
  class HelpDialog <<dialog>> {
    + HelpDialog(singlePlayer : boolean)
  }
  class QuitConfirmDialog <<dialog>> {
    + QuitConfirmDialog(onConfirm : Runnable)
  }
  class EndGameDialog <<dialog>> {
    + EndGameDialog(game : Game, elapsedSeconds : long, onSameSettings : Runnable, onNewSetup : Runnable)
  }
}

package "de.dhbw.memory.view.component" as PComp <<Frame>> {
  class MemoryCard <<component>> {
    + MemoryCard(position : int, theme : Theme, motif : String, onClick : IntConsumer)
    + playEntranceAnimation() : void
    + applyState(card : Card, recentlyMatched : boolean, mismatched : boolean, waiting : boolean, focused : boolean) : void
  }
  class "SegmentedControl<T>" as SegmentedControl <<component>> {
    + SegmentedControl()
    + withVariant(cssClass : String) : SegmentedControl<T>
    + setItems(items : T...) : void
    + setRenderer(renderer : SerializableFunction<T,Component>) : void
    + setValue(value : T) : void
    + getValue() : T
    + addValueChangeListener(listener : SerializableConsumer<T>) : void
  }
}

' ===========================================================
' CONTROLLER LAYER (Spring @Service, @UIScope)
' ===========================================================
package "de.dhbw.memory.controller" as PCtrl <<Frame>> {
  class GameService <<@Service>> {
    - {static} FLIP_BACK_DELAY_MS : long = 1500
    - scheduler : ScheduledExecutorService
    - game : Game
    - theme : Theme
    - startTimeMs : long
    - waitingForFlipBack : boolean {volatile}
    + startGame(playerNames : List<String>, gridSize : int, theme : Theme) : void
    + flip(position : int, ui : UI, afterReset : Runnable) : FlipResult
    + getGame() : Game
    + getTheme() : Theme
    + getElapsedSeconds() : long
    + isWaitingForFlipBack() : boolean
    + shutdown() : void
  }
}

' ===========================================================
' MODEL LAYER (pure Java — no Spring/Vaadin imports)
' ===========================================================
package "de.dhbw.memory.model" as PModel <<Frame>> {
  class Game <<entity>> {
    - players : List<Player>
    - board : Board
    - activePlayerIdx : int
    - firstFlipped : Card
    - secondFlipped : Card
    - totalTurns : int
    + Game(players : List<Player>, board : Board)
    + flip(position : int) : FlipResult
    + resetMismatch() : void
    + isFinished() : boolean
    + winner() : Player
    + isTie() : boolean
    + getActivePlayer() : Player
    + getTotalTurns() : int
    + getPlayers() : List<Player>
    + getBoard() : Board
  }

  class Board <<entity>> {
    - size : int
    - cards : List<Card>
    + Board(size : int, theme : Theme)
    + shuffle(seed : long) : void
    + getCards() : List<Card>
    + getCardAt(position : int) : Card
    + getSize() : int
  }

  class Card <<entity>> {
    - id : int
    - motif : String
    - faceUp : boolean
    - matched : boolean
    + Card(id : int, motif : String)
    + getId() : int
    + getMotif() : String
    + isFaceUp() : boolean
    + isMatched() : boolean
    + flip() : void
    + setMatched(matched : boolean) : void
  }

  class Player <<entity>> {
    - name : String
    - score : int
    - turns : int
    + Player(name : String)
    + getName() : String
    + getScore() : int
    + getTurns() : int
    + addPoint() : void
    + addTurn() : void
  }

  enum Theme <<enumeration>> {
    CRYPTO
    LANGUAGES
    SPACE
    --
    + getFolder() : String
    + getMotifsFor(gridSize : int) : List<String>
    + getDisplayName(motif : String) : String
  }

  enum FlipResult <<enumeration>> {
    FIRST_FLIP
    MATCH
    NO_MATCH
    INVALID
  }
}

' ===========================================================
' RELATIONSHIPS
' ===========================================================

' --- Model
Game "1" *-- "1..2" Player    : players
Game "1" *-- "1"    Board     : board
Board "1" *-- "16..36" Card   : cards
Board ..> Theme       : uses
Game  ..> FlipResult  : returns

' --- Controller → Model
GameService "1" o-- "0..1" Game : owns
GameService ..> Board       : creates
GameService ..> Theme       : reads
GameService ..> FlipResult  : forwards

' --- View → Controller
StartView ..> GameService : start game
GameView  ..> GameService : flip / state

' --- View composition
GameView "1" *-- "16..36" MemoryCard : grid cells
GameView ..> HelpDialog
GameView ..> QuitConfirmDialog
GameView ..> EndGameDialog
StartView ..> SegmentedControl

' --- View → Model (read-only)
StartView     ..> Theme
MemoryCard    ..> Card   : renders
MemoryCard    ..> Theme  : motif folder
EndGameDialog ..> Game
EndGameDialog ..> Player

' --- App entry point
MemoryApplication ..> StartView   : @Route scan
MemoryApplication ..> GameView    : @Route scan
MemoryApplication ..> GameService : component scan

' Force vertical layering: App → View → Controller → Model
PApp   -[hidden]down- PView
PView  -[hidden]down- PCtrl
PCtrl  -[hidden]down- PModel
PView  -[hidden]right- PDialog
PDialog -[hidden]right- PComp

legend right
  | Stereotype | Layer / Role |
  | <<entity>> | Pure Java model — no framework imports |
  | <<enumeration>> | Java enum |
  | <<@Service>> | Spring-managed controller (UI-scoped) |
  | <<@Route>>   | Vaadin top-level view |
  | <<component>>| Reusable Vaadin component |
  | <<dialog>>   | Vaadin modal overlay |
  | <<@SpringBootApplication>> | Application entry point |
endlegend

@enduml
